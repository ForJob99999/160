function SectionAPI:TitleLabel(title, subtitle)
     task.wait()
    local row = self._form:Row({ SearchIndex = title or "" })
    local ts  = row:Left():TitleStack({
        Title    = title    or "",
        Subtitle = subtitle or "",
    })
    return {
        SetTitle    = function(_, t) ts.Title    = t or "" end,
        SetSubtitle = function(_, s) ts.Subtitle = s or "" end,
        Remove      = function()     row:Destroy()         end,
    }
end

-- ── PerkHeader (ชื่อ Perk เป็น Title, [Type] + Ignore เป็น Subtitle) ──
function SectionAPI:PerkHeader(name, perkType, hasIgnore)
     task.wait()
    local typeTag   = string.format("[%s]", perkType or "?")
    local en_sub    = hasIgnore and (typeTag .. "  ◆ Not limited by Slot Type") or typeTag
    local th_sub    = hasIgnore and (typeTag .. "  ◆ ไม่ถูก Slot Type จำกัด")  or typeTag

    local row = self._form:Row({ SearchIndex = name or "" })
    local ts  = row:Left():TitleStack({
        Title    = name  or "",
        Subtitle = en_sub,
    })

    table.insert(getgenv().PerkDetailLabels, {
        label   = { Set = function(_, v) ts.Subtitle = v end },
        prefix  = "",
        english = en_sub,
        thai    = th_sub,
    })

    return { Remove = function() row:Destroy() end }
end

