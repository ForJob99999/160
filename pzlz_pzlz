local function BuildRemoveUidList(selectedGrade)
    local list = GetPetList()
    local removeList = {}

    for _, pet in ipairs(list) do
        local uid = pet.petUid
        local grade = pet.ratingGrade
        local locked = pet.petData and pet.petData.locked == true
        local sparkle = pet.hasSparkle == true

        if uid
            and grade == selectedGrade
            and not locked
            and not sparkle
            and grade ~= "SSS"
        then
            table.insert(removeList, uid)
        end
    end

    return list, removeList
end

local function SellPetsByGrade()
    if not _G.save.SellPetSelect then
        return
    end

    local selectedGrade = _G.save.SelectGrade or "C"
    local minStorageAmount = _G.save.AdjustAmoutStorage or 150

    local list, removeList = BuildRemoveUidList(selectedGrade)

    print("Pet ทั้งหมด:", #list)
    print("เตรียมย่อยเกรด:", selectedGrade, "จำนวน:", #removeList)

    if #list < minStorageAmount then
        print("ยังไม่ถึงจำนวนที่ตั้งไว้:", #list, "/", minStorageAmount)
        return
    end

    if #removeList <= 0 then
        print("ไม่มี pet ที่ตรงเงื่อนไข")
        return
    end

    local args = {
        removeList
    }

    local ok, result = pcall(function()
        return ReqRemovePets:InvokeServer(unpack(args))
    end)

    print("ReqRemovePets:", ok, result)
end

