function SectionAPI:Dropdown(titleOrTable, default, list, callback, forceSearch)
    task.wait()
    local title, subtitle, selectedPrefix

    if type(titleOrTable) == "table" then
        local t = titleOrTable
        local parts = string.split(t.Name or "", "\n")
        title          = parts[1]
        subtitle       = parts[2]
        selectedPrefix = parts[3]
        default        = t.Default
        list           = t.List
        callback       = t.Callback
    else
        local parts    = string.split(titleOrTable, "\n")
        title          = parts[1]
        subtitle       = parts[2]
        selectedPrefix = parts[3]
    end

    local function getList()
        if type(list) == "function" then return list() end
        return list or {}
    end

    local resolvedList = getList()

    local defaultIndex = 1
    if default then
        for i, v in ipairs(resolvedList) do
            if v == default then defaultIndex = i break end
        end
    end

    local function buildSubtitle(selected)
        return subtitle and (
            subtitle:find("%%s")
            and subtitle:format(selected)
            or (subtitle .. "\n" .. (selectedPrefix or "•") .. " " .. selected)
        ) or selected
    end

    local selectedText = default or resolvedList[defaultIndex] or ""
    local row          = self._form:Row({ SearchIndex = title })
    local titleStack   = row:Left():TitleStack({
        Title    = title,
        Subtitle = buildSubtitle(selectedText)
    })

    local pulldown = row:Right():PullDownButton({
        Options  = resolvedList,
        Value    = defaultIndex,
        Search   = #resolvedList > 10,
        ValueChanged = function(self, v)
            local selected = self.Options[v] or ""
            titleStack.Subtitle = buildSubtitle(selected)
            if callback then callback(selected) end
        end,
    })

    return {
        Refresh = function()
            local newList = getList()
            pulldown.Options = newList

            local currentSelected = pulldown.Options[pulldown.Value] or ""
            local stillExists = false

            for _, v in ipairs(newList) do
                if v == currentSelected then
                    stillExists = true
                    break
                end
            end

            if not stillExists then
                pulldown.Value = 1

                local newSelected = newList[1] or ""
                titleStack.Subtitle = buildSubtitle(newSelected)

                if callback then
                    callback(newSelected)
                end
            end
        end,

        Remove = function()
            if row then
                row:Destroy()
            end
        end,

        SetValue = function(v)
            for i, opt in ipairs(pulldown.Options) do
                if opt == v then
                    pulldown.Value = i
                    titleStack.Subtitle = buildSubtitle(v)
                    break
                end
            end
        end
    }
end

function SectionAPI:MultiDropdown(titleOrTable, default, list, callback)
    task.wait()
    local title, subtitle, prefix

    if type(titleOrTable) == "table" then
        local t      = titleOrTable
        local parts  = string.split(t.Name or "", "\n")
        title        = parts[1]
        subtitle     = parts[2]
        prefix       = parts[3]
        default      = t.Default or default
        list         = t.List or list
        callback     = t.Callback or callback
    else
        local parts  = string.split(titleOrTable, "\n")
        title        = parts[1]
        subtitle     = parts[2]
        prefix       = parts[3]
    end

    local function getList()
        if type(list) == "function" then return list() end
        return list or {}
    end

    local resolvedList = getList()

    local defaultIndexes = {}
    local defaultTexts   = {}
    if type(default) == "table" then
        for _, dv in ipairs(default) do
            for i, v in ipairs(resolvedList) do
                if v == dv then
                    table.insert(defaultIndexes, i)
                    table.insert(defaultTexts, v)
                    break
                end
            end
        end
    elseif type(default) == "string" then
        for i, v in ipairs(resolvedList) do
            if v == default then
                table.insert(defaultIndexes, i)
                table.insert(defaultTexts, v)
                break
            end
        end
    end

    local function buildSelectedText(items)
        return #items > 0 and table.concat(items, ", ") or "ไม่ได้เลือก"
    end

    local function formatSubtitle(text)
        if not subtitle then return text end
        if prefix then return subtitle .. "\n" .. prefix .. " " .. text end
        if subtitle:find("%%s") then return subtitle:format(text) end
        return subtitle .. " • " .. text
    end

    local row        = self._form:Row({ SearchIndex = title })
    local titleStack = row:Left():TitleStack({
        Title    = title,
        Subtitle = formatSubtitle(buildSelectedText(defaultTexts))
    })

    local pulldown = row:Right():PullDownButton({
        Options  = resolvedList,
        Multi    = true,
        Value    = defaultIndexes,
        Search   = #resolvedList > 10,
        ValueChanged = function(self, v)
            local selected = {}
            if type(v) == "table" then
                for _, i in ipairs(v) do table.insert(selected, self.Options[i]) end
            elseif type(v) == "number" then
                table.insert(selected, self.Options[v])
            end
            titleStack.Subtitle = formatSubtitle(buildSelectedText(selected))
            if callback then callback(selected) end
        end,
    })

    return {
        Refresh = function()
            local newList = getList()
            pulldown.Options = newList
            local currentIndexes = pulldown.Value or {}
            local stillValid = {}
            for _, i in ipairs(currentIndexes) do
                if newList[i] then
                    table.insert(stillValid, i)
                end
            end
            pulldown.Value = stillValid
            local selectedTexts = {}
            for _, i in ipairs(stillValid) do
                table.insert(selectedTexts, newList[i])
            end
            titleStack.Subtitle = formatSubtitle(buildSelectedText(selectedTexts))
            if callback then
                callback(selectedTexts)
            end
        end,
        SetValue = function(v)
            -- v เป็น table ของ string เช่น {"Highlight", "Name"}
            if type(v) ~= "table" then v = {v} end
            local newIndexes = {}
            local newTexts   = {}
            for _, val in ipairs(v) do
                for i, opt in ipairs(pulldown.Options) do
                    if opt == val then
                        table.insert(newIndexes, i)
                        table.insert(newTexts, opt)
                        break
                    end
                end
            end
            pulldown.Value   = newIndexes
            titleStack.Subtitle = formatSubtitle(buildSelectedText(newTexts))
        end
    }
end
