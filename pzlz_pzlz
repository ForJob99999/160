function SectionAPI:Keybind(titleOrTable, subtitle, default, callback)
     task.wait()
    local title

    if type(titleOrTable) == "table" then
        local t = titleOrTable
        local parts = string.split(t.Name or "", "\n")
        title    = parts[1]
        subtitle = parts[2]
        default  = t.Default
        callback = t.Callback
    else
        local parts = string.split(titleOrTable, "\n")
        title    = parts[1]
        subtitle = parts[2] or subtitle

        -- แบบเก่า: Keybind("title", default, callback) ไม่มี subtitle
        if type(subtitle) == "userdata" or type(subtitle) == "nil" then
            callback = default
            default  = subtitle
            subtitle = parts[2]
        end
    end

    local row = makeRow(self._form, title, subtitle)
    row:Right():KeybindField({
        Value = default,
        ValueChanged = function(_, v)
            if callback then callback(v) end
        end,
    })
end

