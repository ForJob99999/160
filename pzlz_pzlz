local function makeRow(form, title, subtitle)
    local row = form:Row({ SearchIndex = title })
    row:Left():TitleStack({ Title = title, Subtitle = subtitle })
    return row
end

function SectionAPI:Toggle(titleOrTable, subtitle, default, callback) 
    task.wait()
    local title

    if type(titleOrTable) == "table" then
        local t  = titleOrTable
        local parts = string.split(t.Name or "", "\n")
        title    = parts[1]
        subtitle = parts[2]
        default  = t.Default
        callback = t.Callback
    else
        title = titleOrTable
        if type(subtitle) == "boolean" or type(subtitle) == "nil" then
            callback = default
            default  = subtitle
            subtitle = nil
        end
        local parts = string.split(tostring(title), "\n")
        title    = parts[1]
        subtitle = subtitle or parts[2]
    end

    if not self._form then return warn("SectionAPI: Form not found") end

    local row = makeRow(self._form, title, subtitle)
    local toggleObj
    local rightSide = row:Right()
    if rightSide then
        toggleObj = rightSide:Toggle({
            Value = (default == true),
            ValueChanged = function(_, v)
                if type(callback) == "function" then
                    task.spawn(callback, v)
                end
            end,
        })
    end
    return {
        SetValue = function(v)
            if toggleObj then toggleObj.Value = v end
        end
    }
end

function SectionAPI:Slider(titleOrTable, subtitle, min, max, default, formatType, callback)
     task.wait()
    local title

    --// TABLE MODE
    if type(titleOrTable) == "table" then

        local t = titleOrTable
        local parts = string.split(t.Name or "", "\n")

        title      = parts[1]
        subtitle   = parts[2]

        min        = t.Min
        max        = t.Max
        default    = t.Value
        formatType = t.Format
        callback   = t.Callback

    else

        title = titleOrTable

        local parts = string.split(title, "\n")

        title    = parts[1]
        subtitle = parts[2] or subtitle

        -- detect callback
        if type(formatType) == "function" then
            callback = formatType
            formatType = false
        end

    end

    min = min or 0
    max = max or 100

    local startValue = tonumber(default) or min
    startValue = math.floor(math.clamp(startValue, min, max))

    --// FORMATTERS
    local function FormatComma(num)

        local str = tostring(math.floor(num))

        while true do

            local newStr, count = str:gsub("^(-?%d+)(%d%d%d)", "%1,%2")

            str = newStr

            if count == 0 then
                break
            end

        end

        return str

    end

    local function FormatShort(num)

        num = tonumber(num) or 0

        local abs = math.abs(num)

        if abs >= 1e12 then
            return string.format("%.1fT", num / 1e12)

        elseif abs >= 1e9 then
            return string.format("%.1fB", num / 1e9)

        elseif abs >= 1e6 then
            return string.format("%.1fM", num / 1e6)

        elseif abs >= 1e3 then
            return string.format("%.1fK", num / 1e3)

        end

        return tostring(math.floor(num))

    end

    local function FormatNumber(v)

        if formatType == true then
            return FormatShort(v)
        end

        return FormatComma(v)

    end

    local row = self._form:Row({
        SearchIndex = title
    })

    local titleStack = row:Left():TitleStack({
        Title = title,
        Subtitle = subtitle
    })

    local right = row:Right()

    local updating = false
    local textField
    local sliderObject

    --// SLIDER
    sliderObject = right:Slider({

        Minimum = min,
        Maximum = max,
        Value = startValue,

        ValueChanged = function(_, v)

            if updating then
                return
            end

            updating = true

            v = math.floor(v)

            -- textbox sync
            if textField then

                pcall(function()

                    local formatted = FormatNumber(v)

                    if textField.SetValue then
                        textField:SetValue(formatted)
                    else
                        textField.Value = formatted
                    end

                end)

            end

            if callback then
                callback(v)
            end

            updating = false

        end
    })

    --// TEXTBOX
    textField = right:TextField({

        Placeholder = FormatNumber(startValue),
        Value = FormatNumber(startValue),

        ValueChanged = function(_, v)

            if updating then
                return
            end

            -- remove commas/letters
            local cleaned = tostring(v)
                :gsub(",", "")
                :gsub("[Kk]", "000")
                :gsub("[Mm]", "000000")
                :gsub("[Bb]", "000000000")
                :gsub("[Tt]", "000000000000")

            local num = tonumber(cleaned)

            if not num then
                return
            end

            updating = true

            num = math.floor(math.clamp(num, min, max))

            -- textbox sync
            pcall(function()

                local formatted = FormatNumber(num)

                if textField.SetValue then
                    textField:SetValue(formatted)
                else
                    textField.Value = formatted
                end

            end)

            -- slider sync
            pcall(function()

                if sliderObject.SetValue then
                    sliderObject:SetValue(num)
                else
                    sliderObject.Value = num
                end

            end)

            if callback then
                callback(num)
            end

            updating = false

        end
    })

    --// OBJECT
    local obj = {}

    function obj:SetTitle(newTitle)

        local parts = string.split(tostring(newTitle), "\n")

        titleStack.Title = parts[1] or ""
        titleStack.Subtitle = parts[2] or ""

    end

    function obj:SetValue(v)

        v = tonumber(v)

        if not v then
            return
        end

        v = math.floor(math.clamp(v, min, max))

        updating = true

        pcall(function()

            if sliderObject.SetValue then
                sliderObject:SetValue(v)
            else
                sliderObject.Value = v
            end

        end)

        pcall(function()

            local formatted = FormatNumber(v)

            if textField.SetValue then
                textField:SetValue(formatted)
            else
                textField.Value = formatted
            end

        end)

        updating = false

    end

    function obj:GetValue()

        return sliderObject.Value

    end

    function obj:Remove()

        row:Destroy()

    end

    if type(titleOrTable) == "table" and titleOrTable.Key then
        getgenv().UIRegistry = getgenv().UIRegistry or {}
        getgenv().UIRegistry[titleOrTable.Key] = obj
    end
    return obj

end

