repeat task.wait() until game:IsLoaded()
wait(3)
_G.Ryu = true
spawn(function()
	while task.wait() do 
		pcall(function()
			if _G.Ryu then 
				if workspace:FindFirstChild("PartyPads") then
					for i, v in pairs(workspace.PartyPads:GetChildren()) do
						if v:IsA("Model") then
							if not game:GetService("Players").LocalPlayer.PlayerGui.LobbyMatchmaking:FindFirstChild("Frame") then
								if v.Visual.Board.PlayerCount.Text == "0/4" then
									game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = v:GetPivot() + Vector3.new(0, -8, 5)
									wait(1)
								end
							elseif game:GetService("Players").LocalPlayer.PlayerGui.LobbyMatchmaking:FindFirstChild("Frame") then
								print(222222222222222)
								local args = {
									buffer.fromstring("\b\001"),
									{}
								}
								game:GetService("ReplicatedStorage"):WaitForChild("ZAP"):WaitForChild("ZAP_RELIABLE"):FireServer(unpack(args))
								if game:GetService("Players").LocalPlayer.PlayerGui.LobbyMatchmaking.Frame.Frame:GetChildren()[8].Text == "CREATE" then
									game:GetService("GuiService").SelectedObject = game:GetService("Players").LocalPlayer.PlayerGui.LobbyMatchmaking.Frame.Frame:GetChildren()[8]
									game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.Return, false, game)
									game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.Return, false, game)
								end
								wait(1)
							end
						end
					end
				elseif not workspace:FindFirstChild("PartyPads") then

					function GetMoneyNumber() 
						local text = game:GetService("Players").LocalPlayer.PlayerGui.Money.TextLabel.Text 
						return tonumber((text:gsub("%D", ""))) or 0 
					end 

					if GetMoneyNumber() >= 100 then
						print("สำเร็จ")
						local found = false
						for i,v in pairs(workspace.Containers:GetChildren()) do 
							if v:IsA("Model") and string.find(v.Name,"Chest") then 
								for _,v2 in pairs(v:GetDescendants()) do 
									if v2.Name == "ProximityPrompt" then 
										found = true
										game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = v2.Parent.CFrame 
										wait(0.5)
										fireproximityprompt(v2)
										wait(0.5)
									end
								end
							end
						end
						if not found then
							print("ไม่เจอ")
							local args = {
							buffer.fromstring("\027"),
								{}
							}
							game:GetService("ReplicatedStorage"):WaitForChild("ZAP"):WaitForChild("ZAP_RELIABLE"):FireServer(unpack(args))
						end
					elseif GetMoneyNumber() < 100 then
						print("ไม่สำเร็จ")
						require(game:GetService("ReplicatedStorage").Client.ClientRemotes).cashTips.replicateCashTip.setCallback(function(p)
							print("firing id:", p.id)
							task.wait()
							local args = {
								buffer.fromstring("\002#" .. p.id),
								{}
							}
							game:GetService("ReplicatedStorage"):WaitForChild("ZAP"):WaitForChild("ZAP_RELIABLE"):FireServer(unpack(args))
						end)
						game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = workspace.World.Bank.BankVault.CashArea.CFrame
						wait(1)
						local args = {
							buffer.fromstring(";"),
							{}
						}
						game:GetService("ReplicatedStorage"):WaitForChild("ZAP"):WaitForChild("ZAP_RELIABLE"):FireServer(unpack(args))
					end
				end
			end
		end)
	end
end)

local player = game:GetService("Players").LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "Watermark"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local label = Instance.new("TextLabel")
label.Size = UDim2.new(0, 600, 0, 30)
label.Position = UDim2.new(0.5, -300, 0, 10) 
label.BackgroundTransparency = 1
label.Text = "⚠️ สคริปต์นี้ทำโดยค่าย Vector Hub ในราคา 160 บาท คนทำ Ryuenz ไม่อนุญาตให้นำไปขายต่อ"
label.TextColor3 = Color3.fromRGB(255, 255, 255)
label.TextStrokeTransparency = 0  
label.TextScaled = true
label.Font = Enum.Font.GothamBold
label.Parent = screenGui
