local CW = {}
CW.__index = CW


function CW.new(options)
    local self = setmetatable({}, CW)
    self._app = cascade.New({
        Theme = options.Theme or cascade.Themes.Dark,
        Accent = options.Accent or cascade.Accents.Blue,
    })
    self._win = self._app:Window({
        Title = options.Title or "Hub",
        Subtitle = options.Subtitle or "",
        UIBlur = not isMobile,      -- ✅ ปิด UIBlur บน Mobile
        Dropshadow = not isMobile,  -- ✅ ปิด Dropshadow บน Mobile ด้วย
        Size = options.Size or UDim2.fromOffset(850, 530),
    })
    self._tabs = {}
    return self
end
function CW:CreateTab(sectionTitleOrTable, tabTitle, icon, sectionGroup, selected)
    
    if not self._sections then self._sections = {} end
    
    local sec
    if sectionGroup and type(sectionGroup) == "string" then
        if not self._sections[sectionGroup] then
            self._sections[sectionGroup] = self._win:Section({ 
                Disclosure = true, 
                Title = sectionGroup 
            })
        end
        sec = self._sections[sectionGroup]
    else
        if type(sectionGroup) == "boolean" then
            selected = sectionGroup
        end
        sec = self._win:Section({ Title = sectionTitleOrTable })
    end

    local tab = sec:Tab({
        Title = tabTitle,
        Icon = icon and cascade.Symbols[icon] or nil,
        Selected = selected or false,
    })

    local T = { _tab = tab, _app = self._app }
    setmetatable(T, { __index = TabAPI })
    return T
end


function CW:Notify(options)
    self._app:Notification({
        Title = options.Title or "",
        Subtitle = options.Subtitle or "",
        Duration = options.Duration or 3,
        Icon = options.Icon and cascade.Symbols[options.Icon] or nil,
    })
end

TabAPI = {}
TabAPI.__index = TabAPI

function TabAPI:CreateSection(name)
    local title = type(name) == "table" and name.Name or name
    
    local ps = self._tab:PageSection({ Title = title })
    local form = ps:Form()
    local S = {
        _form = form,
        _app = self._app,
        _pageSection = ps
    }

    function S:Remove()
        if self._pageSection then
            self._pageSection:Destroy()
        end
    end

    setmetatable(S, { __index = SectionAPI })
    return S
end

