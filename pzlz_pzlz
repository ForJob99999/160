getgenv().ConfigSection = Config:CreateSection("Settings-Config")

local CONFIG_PATH = "VectorHub/evomonpzlz/"
local PLAYER_NAME = game.Players.LocalPlayer.Name

-- เก็บ meta (AutoLoad, SelectedConfig)
local meta = {
    AutoLoad = false,
    SelectedConfig = nil
}

-- โหลด meta
local function LoadMeta()
    local path = CONFIG_PATH .. PLAYER_NAME .. "_meta.json"
    if isfile(path) then
        local ok, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(readfile(path))
        end)
        if ok and data then
            meta.AutoLoad = data.AutoLoad or false
            meta.SelectedConfig = data.SelectedConfig or nil
        end
    end
end

-- บันทึก meta
local function SaveMeta()
    writefile(CONFIG_PATH .. PLAYER_NAME .. "_meta.json",
        game:GetService("HttpService"):JSONEncode(meta))
end

-- ดึงรายชื่อ config ทั้งหมด
local function GetConfigList()
    local list = {}
    for _, file in ipairs(listfiles(CONFIG_PATH)) do
        local name = file:match(PLAYER_NAME .. "_(.+)%.json$")
        if name and name ~= "meta" then
            table.insert(list, name)
        end
    end
    return list
end

-- สร้าง config ใหม่
local function CreateConfig(configName)
    if configName == "" or configName == nil then return end
    local path = CONFIG_PATH .. PLAYER_NAME .. "_" .. configName .. ".json"
    writefile(path, game:GetService("HttpService"):JSONEncode(_G.save))
end

-- โหลด config ที่เลือก
local function LoadConfig(configName)
    if configName == nil then return end
    local path = CONFIG_PATH .. PLAYER_NAME .. "_" .. configName .. ".json"
    if not isfile(path) then return end
    local ok, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(readfile(path))
    end)
    if ok and data then
        for k, v in pairs(data) do
            _G.save[k] = v
        end
        meta.SelectedConfig = configName
        SaveMeta()

        -- อัปเดต UI
        local registry = getgenv().UIRegistry
        if registry then
            for key, obj in pairs(registry) do
                if obj and obj.SetValue and _G.save[key] ~= nil then
                    obj.SetValue(_G.save[key])
                end
            end
        end
    end
end

-- เขียนทับ config ที่เลือกไว้
local function OverwriteConfig()
    if meta.SelectedConfig == nil then return end
    CreateConfig(meta.SelectedConfig)
end

-- ลบ config
local function DeleteConfig(configName)
    if configName == nil then return end
    local path = CONFIG_PATH .. PLAYER_NAME .. "_" .. configName .. ".json"
    if isfile(path) then
        delfile(path)
        if meta.SelectedConfig == configName then
            meta.SelectedConfig = nil
            SaveMeta()
        end
    end
end

-- AutoLoad ตอนเริ่ม
LoadMeta()
if meta.AutoLoad and meta.SelectedConfig then
    LoadConfig(meta.SelectedConfig)
end

