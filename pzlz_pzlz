function SectionAPI:Choice(titleOrTable, list, value, callback)
     task.wait()

    local title, subtitle

    --// Table API
    if type(titleOrTable) == "table" then

        local t = titleOrTable
        local parts = string.split(t.Name or "", "\n")

        title    = parts[1]
        subtitle = parts[2]

        list     = t.List or {}
        value    = t.Value
        callback = t.Callback

    else

        local parts = string.split(titleOrTable, "\n")

        title    = parts[1]
        subtitle = parts[2]

    end

    list = list or {}

    local CurrentValue = value or list[1]

    --// Main Row
    local row = self._form:Row({
        SearchIndex = title
    })

    local titleStack = row:Left():TitleStack({
        Title = title,
        Subtitle = subtitle
            and (subtitle .. " • " .. tostring(CurrentValue))
            or tostring(CurrentValue)
    })

    --// Right Side
    local right = row:Right()

    --// Buttons
    local Buttons = {}

    --// Refresh UI
    local function Refresh()

        for option, btn in pairs(Buttons) do

            local selected = (option == CurrentValue)

            -- Update Text
            btn.Label = selected
                and ("● " .. tostring(option))
                or ("○ " .. tostring(option))

            -- Update Color
            btn.State = selected
                and "Primary"
                or "Secondary"
        end

        -- Update Subtitle
        titleStack.Subtitle = subtitle
            and (subtitle .. " • " .. tostring(CurrentValue))
            or tostring(CurrentValue)
    end
    

    --// Create Buttons
    for _, option in ipairs(list) do

        local btn = right:Button({
            Label = "",
            State = "Secondary",

            Pushed = function()

                CurrentValue = option

                Refresh()

                if callback then
                    task.spawn(callback, option)
                end
            end
        })

        Buttons[option] = btn
    end

    Refresh()
    if callback and CurrentValue ~= nil then
        task.spawn(callback, CurrentValue)
    end
    --// Return Object
    local obj = {}

    function obj:Set(newValue)

        if Buttons[newValue] then

            CurrentValue = newValue

            Refresh()

            if callback then
                task.spawn(callback, newValue)
            end
        end
    end

    function obj:Get()
        return CurrentValue
    end

    function obj:Destroy()

        if row then
            row:Destroy()
        end
    end

    return obj
end

