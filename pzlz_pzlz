local function findKnownPetInCreature(creature)
    local directPet = modelToPet[creature.Name]
    if directPet then
        return directPet, creature.Name
    end

    for _, obj in ipairs(creature:GetDescendants()) do
        local pet = modelToPet[obj.Name]
        if pet then
            return pet, obj.Name
        end
    end

    return nil, nil
end
