-- loader.lua
-- โหลดไฟล์นี้ใน executor แล้วใส่ Key

local API_URL = "https://mochibot.serveousercontent.com/api/redeem"  -- เปลี่ยนเป็น URL ของคุณ
local KEY_FILE = "airi_key.txt"  -- เก็บ key ใน file executor

-- ── ดึง HWID ──
local function getHWID()
    -- ใช้ RbxAnalyticsService หรือ PlayerService เพื่อดึง device ID
    local success, id = pcall(function()
        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    if success and id and id ~= "" then
        return id
    end
    -- fallback: ใช้ UserId เป็น HWID (เฉพาะ Roblox)
    return tostring(game.Players.LocalPlayer.UserId)
end

-- ── อ่าน Key จากไฟล์ ──
local function readKey()
    if not isfile(KEY_FILE) then return nil end
    local k = readfile(KEY_FILE)
    return k and k:match("^%s*(.-)%s*$") or nil  -- trim whitespace
end

-- ── เขียน Key ลงไฟล์ ──
local function saveKey(key)
    writefile(KEY_FILE, key)
end

-- ── Verify กับ API ──
local function verifyKey(key, hwid)
    local body = game:GetService("HttpService"):JSONEncode({key = key, hwid = hwid})
    local ok, res = pcall(function()
        return game:GetService("HttpService"):PostAsync(API_URL, body, Enum.HttpContentType.ApplicationJson)
    end)
    if not ok then
        return false, "ไม่สามารถเชื่อมต่อ API ได้"
    end
    local data = game:GetService("HttpService"):JSONDecode(res)
    return data.ok == true, data.msg or ""
end

-- ══════════════════════════════════════════════
--  MAIN
-- ══════════════════════════════════════════════

local hwid = getHWID()
local key  = readKey()

if not key or key == "" then
    -- ยังไม่มี key → ขอให้กรอก
    key = game:GetService("HttpService"):JSONDecode(
        game:GetService("HttpService"):PostAsync(
            "rbxassetid://",  -- placeholder UI input
            ""
        )
    )
    -- ใช้ง่ายๆ: prompt ผ่าน textbox ใน GUI (ดู script.lua)
    warn("[Airi] ไม่พบ Key กรุณากรอก Key ใน GUI")
    return
end

-- Verify
local success, msg = verifyKey(key, hwid)
if success then
    saveKey(key)  -- เก็บ key ไว้ใช้ครั้งต่อไป
    -- โหลด script หลัก
    loadstring(game:HttpGet("https://raw.githubusercontent.com/ForJob99999/160/refs/heads/main/TEST.lua"))()
else
    -- ลบ key ที่ผิดออก
    if isfile(KEY_FILE) then delfile(KEY_FILE) end
    error("[Airi] Key ไม่ถูกต้อง: " .. msg)
end
