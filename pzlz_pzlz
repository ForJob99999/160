getgenv().StopFly = function()
    getgenv().FLYING = false
    getgenv().cleanupFlyConnections()

    local root = getgenv().getRoot(getgenv().Character)
    if root then
        local bv = root:FindFirstChild("BodyVelocity")
        local bg = root:FindFirstChild("BodyGyro")
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end

    local hum = getgenv().getHumanoid()
    if hum then hum.PlatformStand = false end

    if getgenv().Camera then getgenv().Camera.CameraType = Enum.CameraType.Custom end
end

getgenv().StartFly = function(vfly)
    getgenv().StopFly()
    if not getgenv().Character then getgenv().LocalPlayer.CharacterAdded:Wait() end

    local root     = getgenv().getRoot(getgenv().Character)
    local humanoid = getgenv().getHumanoid()
    if not root or not humanoid then return end

    getgenv().FLYING = true
    local CONTROL  = {F=0,B=0,L=0,R=0,Q=0,E=0}
    local lCONTROL = {F=0,B=0,L=0,R=0,Q=0,E=0}
    local SPEED    = 0

    local bg = Instance.new("BodyGyro")
    bg.Name = "BodyGyro"
    bg.P = 9e4
    bg.MaxTorque = Vector3.new(9e9,9e9,9e9)
    bg.CFrame = root.CFrame
    bg.Parent = root

    local bv = Instance.new("BodyVelocity")
    bv.Name = "BodyVelocity"
    bv.MaxForce = Vector3.new(9e9,9e9,9e9)
    bv.Velocity = Vector3.new(0,0,0)
    bv.Parent = root

    getgenv().flyConnections.flyLoop = getgenv().RunService.Heartbeat:Connect(function()
        if not getgenv().FLYING or not root.Parent then getgenv().StopFly() return end
        if not vfly then humanoid.PlatformStand = true end

        if CONTROL.L+CONTROL.R ~= 0 or CONTROL.F+CONTROL.B ~= 0 or CONTROL.Q+CONTROL.E ~= 0 then
            SPEED = 50
        elseif SPEED ~= 0 then
            SPEED = 0
        end

        if (CONTROL.L+CONTROL.R) ~= 0 or (CONTROL.F+CONTROL.B) ~= 0 or (CONTROL.Q+CONTROL.E) ~= 0 then
            local cf = getgenv().Camera.CFrame
            bv.Velocity = ((cf.LookVector*(CONTROL.F+CONTROL.B))+((cf*CFrame.new(CONTROL.L+CONTROL.R,(CONTROL.F+CONTROL.B+CONTROL.Q+CONTROL.E)*0.2,0).Position)-cf.Position))*SPEED
            lCONTROL = {F=CONTROL.F,B=CONTROL.B,L=CONTROL.L,R=CONTROL.R,Q=CONTROL.Q,E=CONTROL.E}
        elseif SPEED ~= 0 then
            local cf = getgenv().Camera.CFrame
            bv.Velocity = ((cf.LookVector*(lCONTROL.F+lCONTROL.B))+((cf*CFrame.new(lCONTROL.L+lCONTROL.R,(lCONTROL.F+lCONTROL.B+lCONTROL.Q+lCONTROL.E)*0.2,0).Position)-cf.Position))*SPEED
        else
            bv.Velocity = Vector3.new(0,0,0)
        end
        bg.CFrame = getgenv().Camera.CFrame
    end)

    getgenv().flyConnections.keyDown = getgenv().UserInputService.InputBegan:Connect(function(input, processed)
        if not getgenv().FLYING or processed then return end
        local key   = input.KeyCode
        local speed = vfly and _G.VFlySpeed or _G.FlySpeed
        if     key == Enum.KeyCode.W then CONTROL.F = speed
        elseif key == Enum.KeyCode.S then CONTROL.B = -speed
        elseif key == Enum.KeyCode.A then CONTROL.L = -speed
        elseif key == Enum.KeyCode.D then CONTROL.R = speed
        elseif _G.QEFlyEnabled and key == Enum.KeyCode.E then CONTROL.Q = speed * 2
        elseif _G.QEFlyEnabled and key == Enum.KeyCode.Q then CONTROL.E = -speed * 2
        end
        getgenv().Camera.CameraType = Enum.CameraType.Track
    end)

    getgenv().flyConnections.keyUp = getgenv().UserInputService.InputEnded:Connect(function(input)
        if not getgenv().FLYING then return end
        local key = input.KeyCode
        if     key == Enum.KeyCode.W then CONTROL.F = 0
        elseif key == Enum.KeyCode.S then CONTROL.B = 0
        elseif key == Enum.KeyCode.A then CONTROL.L = 0
        elseif key == Enum.KeyCode.D then CONTROL.R = 0
        elseif key == Enum.KeyCode.E then CONTROL.Q = 0
        elseif key == Enum.KeyCode.Q then CONTROL.E = 0
        end
    end)
end

getgenv().StartMobileFly = function(vfly)
    getgenv().StopFly()
    if not getgenv().Character then getgenv().LocalPlayer.CharacterAdded:Wait() end

    local root     = getgenv().getRoot(getgenv().Character)
    local humanoid = getgenv().getHumanoid()
    if not root or not humanoid then return end

    getgenv().FLYING = true
    local v3inf  = Vector3.new(9e9,9e9,9e9)
    local v3zero = Vector3.new(0,0,0)

    local bv = Instance.new("BodyVelocity")
    bv.Name = "BodyVelocity"
    bv.MaxForce = v3zero
    bv.Velocity = v3zero
    bv.Parent = root

    local bg = Instance.new("BodyGyro")
    bg.Name = "BodyGyro"
    bg.MaxTorque = v3inf
    bg.P = 1000
    bg.D = 50
    bg.Parent = root

    local controlModule = require(getgenv().LocalPlayer.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("ControlModule"))

    getgenv().flyConnections.mobileLoop = getgenv().RunService.Heartbeat:Connect(function()
        if not getgenv().FLYING then getgenv().StopFly() return end
        local cr = getgenv().getRoot(getgenv().Character)
        local ch = getgenv().getHumanoid()
        if not cr or not ch then return end

        local vh = cr:FindFirstChild("BodyVelocity")
        local gh = cr:FindFirstChild("BodyGyro")
        if not vh or not gh then return end

        vh.MaxForce = v3inf
        gh.MaxTorque = v3inf

        if not vfly then ch.PlatformStand = true end
        gh.CFrame = getgenv().Camera.CFrame
        vh.Velocity = v3zero

        local speed     = vfly and _G.VFlySpeed or _G.FlySpeed
        local direction = controlModule:GetMoveVector()
        local cf        = getgenv().Camera.CFrame

        if direction.Magnitude > 0 then
            vh.Velocity = cf.RightVector*(direction.X*speed*50) - cf.LookVector*(direction.Z*speed*50)
        end
    end)
end

getgenv().ToggleFly = function(vfly)
    if (vfly and _G.VFlyEnabled) or (not vfly and _G.FlyEnabled) then
        if getgenv().IsOnMobile then
            getgenv().StartMobileFly(vfly)
        else
            getgenv().StartFly(vfly)
        end
    else
        getgenv().StopFly()
    end
end

