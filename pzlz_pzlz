-- safeGet
function safeGet(root, ...)
    local current = root
    for _, key in ipairs({...}) do
        if typeof(current) == "Instance" then
            current = current:FindFirstChild(key)
        else
            return nil
        end
        if current == nil then
            --warn("[safeGet] ไม่เจอ: " .. tostring(key))
            return nil
        end
    end
    return current
end



